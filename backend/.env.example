# Google Gemini API key 
GEMINI_API_KEY= Enter gemini api key generated from Google AI studio

# Server configuration
PORT=8000
HOST=127.0.0.1

GOOGLE_CLIENT_ID= Enter your google CLIENT_ID(same as you entered in frontend\env)

MYSQL_HOST= Enter HOST
MYSQL_USER= Enter your username
MYSQL_PASSWORD= Enter you password
MYSQL_DATABASE= Enter database name
